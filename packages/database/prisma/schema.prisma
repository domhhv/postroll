generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  username  String?
  createdAt DateTime @default(now())

  @@map("users")
}
